{
	"bsonType": "object",//固定节点
	"required": [//必填字段
		"name"
	],
	"permission": {
		"read": true,
		"create": "'manage' in auth.role",
		"update": "'UPDATE_PERMISSION' in auth.permission",
		"delete": "'DELETE_PERMISSION' in auth.permission"
	},
	"properties": {
		"_id": {
			"description": "存储文档 ID（文章 ID），系统自动生成"
		},
		"name": {
			"bsonType": "string",//字段类型
			"description": "类别名称",//备注
			"label": "名称",
			"trim": "both",
			"minLength": 2,
			"maxLength": 6
		},
		"select": {
			"bsonType": "bool",
			"description": "是否推荐，默认false，true是精选",
			"defaultValue" : false
		},
		"enable": {
			"bsonType": "bool",
			"description": "是否启用，默认false，true是精选",
			"defaultValue" : false
		},
		"sort": {
			"bsonType": "int",
			"description": "类别显示顺序",
			"label": "排序"
		},
		"picurl": {
			"bsonType": "string",
			"description": "缩略图地址"
		},
		"createTime": {
			"bsonType": "timestamp",
			"description": "创建时间",
			"forceDefaultValue": {//一个特定的字段，规定上传当时的时间到数据库
				"$env": "now"
			}
		}
	},
	"version": "0.0.1"
}